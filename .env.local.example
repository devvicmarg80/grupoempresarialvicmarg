# ─── VICMARG Platform Environment Variables ─────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── OpenAI (AI Receptionist) ────────────────────────────────────────────────
# Required for Phase 6.2 — AI Receptionist (OpenAI Realtime API)
# Get at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── ElevenLabs (Optional — premium branded voice) ───────────────────────────
# If set, overrides OpenAI TTS with ElevenLabs voice synthesis.
# Get at: https://elevenlabs.io/app/voice-lab
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...   # Clone VICMARG voice here for maximum brand consistency

# ─── AI Feature Flags (client-visible via NEXT_PUBLIC_) ──────────────────────
# Enable AI Receptionist (set to 'true' when API keys are configured)
NEXT_PUBLIC_AI_ENABLED=false

# Enable OpenAI TTS (set to 'true' if you want TTS without ElevenLabs)
NEXT_PUBLIC_AI_TTS_ENABLED=false

# ElevenLabs voice ID exposed to TTS provider factory (client-safe — no key)
NEXT_PUBLIC_ELEVENLABS_VOICE_ID=

# ─── Cloudflare (Phase 6.1 — Real video assets) ──────────────────────────────
# When Cloudflare R2 is configured, update VIDEO_MANIFESTS in:
# src/config/scenes.config.ts
#
# HLS manifest format:
#   ARRIVAL:    https://your-account.cloudflarestream.com/{video-id}/manifest/video.m3u8
#   GREETING:   https://your-account.cloudflarestream.com/{video-id}/manifest/video.m3u8
#   DISCOVERY:  https://your-account.cloudflarestream.com/{video-id}/manifest/video.m3u8
#   CONVERSION: https://your-account.cloudflarestream.com/{video-id}/manifest/video.m3u8
#
# Or R2 custom domain:
#   https://media.grupoempresarialvicmarg.com/videos/scenes/arrival/master.m3u8

# ─── Supabase (Phase 7 — User data + CRM) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...   # Server-only — never expose to client
